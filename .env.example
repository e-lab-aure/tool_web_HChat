# Serveur
PORT=5000
HOST=0.0.0.0
APP_NAME=HChat

# Stockage
UPLOAD_DIR=uploads
DATA_DIR=data

# Limites
MAX_UPLOAD_SIZE_MB=10
MAX_MESSAGE_SIZE_KB=64
MAX_HISTORY=100

# Types de fichiers autorises (separés par virgule, sans espaces)
ALLOWED_EXTENSIONS=pdf,xlsx,xls,docx,doc,txt,png,jpg,jpeg,gif,webp,zip,csv,md,py,js,ts,json

# Rate limiting (messages par fenetre)
RATE_LIMIT_MESSAGES=30
RATE_LIMIT_WINDOW=60

# Logging
LOG_FILE=chat.log
LOG_LEVEL=INFO
